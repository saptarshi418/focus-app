<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FocusTimer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="switchStyle">@style/SwitchStyle</item>
    </style>

    <style name="Theme.FocusTimer.Overlay" parent="Theme.FocusTimer">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="SwitchStyle" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/white</item>
        
    </style>
</resources>
